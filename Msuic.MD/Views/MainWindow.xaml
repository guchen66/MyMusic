<Window
    x:Class="Music.MD.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:daoMarkup="clr-namespace:IT.Tangdao.Core.Markup;assembly=IT.Tangdao.Core"
    xmlns:local="clr-namespace:Music.MD"
    xmlns:markup="clr-namespace:Music.MD.Markup"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:region="clr-namespace:Music.Shared.Common;assembly=Music.Shared"
    Title="{markup:Loc ResxKey='Title'}"
    Width="1200"
    Height="800"
    prism:ViewModelLocator.AutoWireViewModel="True"
    WindowStartupLocation="CenterScreen">
    <DockPanel>
        <ContentControl DockPanel.Dock="Bottom" Height="50"
                    prism:RegionManager.RegionName="{x:Static region:RegionNames.FooterRegion}" />

        <!-- 上半部分再用 Grid 做左右分割，可读性更高 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <ContentControl prism:RegionManager.RegionName="{x:Static region:RegionNames.AsideRegion}" />
            <ContentControl Grid.Column="1"
                        prism:RegionManager.RegionName="{x:Static region:RegionNames.ContentRegion}" />
        </Grid>
    </DockPanel>
</Window>