<Window
    x:Class="Music.MD.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i18n="clr-namespace:Music.MD.I18n"
    xmlns:local="clr-namespace:Music.MD.Views"
    xmlns:markup="clr-namespace:Music.MD.Markup"
    xmlns:daoMarkup="clr-namespace:IT.Tangdao.Core.Markup;assembly=IT.Tangdao.Core"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    Title="LoginWindow"
    Width="650"
    Height="390"
    prism:ViewModelLocator.AutoWireViewModel="True"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger x:Name="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid MouseLeftButtonDown="Grid_MouseLeftButtonDown">
        <Border
            Height="390"
            VerticalAlignment="Top"
            Background="#000000"
            CornerRadius="0 0 120 0" />
        <StackPanel Orientation="Horizontal">
            <StackPanel Width="350" Panel.ZIndex="1">
                <StackPanel Margin="20,40,20,40">
                    <TextBlock
                        Margin="20"
                        FontFamily="Great Vibes"
                        FontSize="35"
                        Foreground="White"
                        Text="{markup:Loc ResxKey='Title'}"
                        TextAlignment="Center" />
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <md:PackIcon
                            Width="30"
                            Height="30"
                            Foreground="White"
                            Kind="User" />
                        <TextBox
                            x:Name="txtUsername"
                            Width="250"
                            Margin="10,0"
                            md:HintAssist.Hint="{markup:Loc ResxKey='InputName'}"
                            BorderBrush="White"
                            CaretBrush="#FFD94448"
                            FontSize="16"
                            Foreground="White"
                            SelectionBrush="#FFD94448"
                            Text="{Binding LoginInputDto.UserName}" />
                    </StackPanel>
                    <StackPanel Margin="10" Orientation="Horizontal">
                        <md:PackIcon
                            Width="30"
                            Height="30"
                            Foreground="White"
                            Kind="Lock" />
                        <PasswordBox
                            x:Name="txtPassword"
                            Width="250"
                            Margin="10,0"
                            md:HintAssist.Hint="{markup:Loc ResxKey='InputPwd'}"
                            md:PasswordBoxAssist.Password="{Binding LoginInputDto.Password, Mode=TwoWay}"
                            BorderBrush="White"
                            CaretBrush="#FFD94448"
                            FontSize="16"
                            Foreground="White"
                            SelectionBrush="#FFD94448" />
                    </StackPanel>
                    <StackPanel Margin="10,40,10,10" HorizontalAlignment="Center">
                        <Button
                            x:Name="btnLogin"
                            Width="100"
                            Height="40"
                            Background="#D94448"
                            BorderBrush="#D94448"
                            BorderThickness="2"
                            Command="{Binding LoginCommand}"
                            CommandParameter="{daoMarkup:GetWindow}"
                            Content="{markup:Loc ResxKey='Login'}"
                            Foreground="White"
                            IsDefault="True"
                            ToolTip="登录" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel Width="384" Margin="-85,40">
                <Image
                    Width="384"
                    Height="240"
                    VerticalAlignment="Top"
                    Source="{StaticResource LoginBackground}"
                    Stretch="Fill" />
            </StackPanel>
            <StackPanel Margin="30,0,0,0" HorizontalAlignment="Right">
                <Button
                    Height="auto"
                    Background="#000000"
                    BorderBrush="#000000"
                    IsCancel="True"
                    ToolTip="关闭">
                    <md:PackIcon
                        Width="30"
                        Height="30"
                        Foreground="White"
                        Kind="Power" />
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>