<mah:MetroWindow
    x:Class="Music.Mah.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:markup="clr-namespace:Music.Mah.Markup"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:region="clr-namespace:Music.Shared.Common;assembly=Music.Shared"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    Title="{markup:Loc ResxKey='Title'}"
    Width="1200"
    Height="800"
    WindowStartupLocation="CenterScreen"
    prism:ViewModelLocator.AutoWireViewModel="True">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <DockPanel>
        <ContentControl DockPanel.Dock="Bottom" Height="50"
                 prism:RegionManager.RegionName="{x:Static region:RegionNames.FooterRegion}" />

        <!-- 上半部分再用 Grid 做左右分割，可读性更高 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <ContentControl prism:RegionManager.RegionName="{x:Static region:RegionNames.AsideRegion}" />
            <ContentControl Grid.Column="1"
                     prism:RegionManager.RegionName="{x:Static region:RegionNames.ContentRegion}" />
        </Grid>
    </DockPanel>
</mah:MetroWindow>