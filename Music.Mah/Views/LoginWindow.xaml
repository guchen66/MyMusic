<mah:MetroWindow
    x:Class="Music.Mah.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:daoMarkup="clr-namespace:IT.Tangdao.Core.Markup;assembly=IT.Tangdao.Core"
    xmlns:iconPack="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:Music.Mah.Views"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:markup="clr-namespace:Music.Mah.Markup"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:prism="http://prismlibrary.com/"
    Width="650"
    Height="390"
    prism:ViewModelLocator.AutoWireViewModel="True"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
     Title="{markup:Loc ResxKey='Title'}"
    WindowStyle="None"
    mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Border
            Height="390"
            VerticalAlignment="Top"
            Background="#000000"
            CornerRadius="0 0 120 0" />
        <StackPanel Orientation="Horizontal">
            <StackPanel Width="350" Panel.ZIndex="1">
                <StackPanel Margin="20,40,20,40">
                    <TextBlock
                        Margin="20"
                        FontFamily="Great Vibes"
                        FontSize="35"
                        Foreground="White"
                        Text="{markup:Loc ResxKey='Title'}"
                        TextAlignment="Center" />
                    <StackPanel Margin="10" Orientation="Horizontal">

                        <TextBox
                            Width="250"
                            Margin="10,0"
                            mah:TextBoxHelper.ClearTextButton="True"
                            mah:TextBoxHelper.Watermark="{markup:Loc ResxKey='InputName'}"
                            BorderBrush="White"
                            CaretBrush="#FFD94448"
                            FontSize="16"
                            SelectionBrush="#FFD94448"
                            Text="{Binding LoginInputDto.UserName}" />
                    </StackPanel>
                    <StackPanel Margin="10" Orientation="Horizontal">

                        <PasswordBox
                            Name="PasswordBox"
                            Width="250"
                            Margin="10,0"
                            VerticalAlignment="Center"
                            mah:PasswordBoxBindingBehavior.Password="{Binding LoginInputDto.Password}"
                            mah:TextBoxHelper.ClearTextButton="True"
                            mah:TextBoxHelper.Watermark="{markup:Loc ResxKey='InputPwd'}"
                            FontSize="16" />
                    </StackPanel>
                    <StackPanel Margin="10,40,10,10" HorizontalAlignment="Center">
                        <Button
                            x:Name="btnLogin"
                            Width="100"
                            Background="#D94448"
                            BorderBrush="#D94448"
                            BorderThickness="2"
                            Command="{Binding LoginCommand}"
                            CommandParameter="{daoMarkup:GetWindow}"
                            Content="{markup:Loc ResxKey='Login'}"
                            Foreground="White"
                            IsDefault="True"
                            ToolTip="登录" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
            <StackPanel Width="384" Margin="-85,40">
                <Image
                    Width="384"
                    Height="240"
                    VerticalAlignment="Top"
                    Source="{StaticResource LoginBackground}"
                    Stretch="Fill" />
            </StackPanel>
        </StackPanel>
    </Grid>
</mah:MetroWindow>