<UserControl x:Class="MyMusic.Views.Dialog.DownLoadDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:MyMusic.Views.Dialog"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d">
    <materialDesign:Card
       Padding="16"
       HorizontalAlignment="Center"
       VerticalAlignment="Center">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="60" />
            </Grid.RowDefinitions>
            <StackPanel  Height="30">
                <TextBlock FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Run Text="是否下载" />
                    <Run Text="{Binding DownLoadMusicName}" />
                    <Run Text="?" />
                </TextBlock>
            </StackPanel>
            <StackPanel
               Grid.Row="1"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Orientation="Horizontal">
                <Button
                   Width="80"
                   Margin="10,10,10,10"
                   Command="{Binding ConfirmCommand}"
                   Content="确认"
                   Style="{StaticResource MaterialDesignFlatDarkBgButton}" />
                <Button
                   Width="80"
                   Margin="10,10,10,10"
                   Command="{Binding CancelCommand}"
                   Content="取消"
                   Style="{StaticResource MaterialDesignPaperButton}" />
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</UserControl>